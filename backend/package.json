{
  "name": "arca-server-backend",
  "version": "1.0.0",
  "description": "Backend for invoicing app integrated with AFIP/ARCA",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@ramiidv/arca-agro": "^0.1.0",
    "@ramiidv/arca-cdc": "^0.1.0",
    "@ramiidv/arca-common": "^0.1.0",
    "@ramiidv/arca-empleados": "^0.1.0",
    "@ramiidv/arca-facturacion": "^2.0.0",
    "@ramiidv/arca-fecred": "^0.1.0",
    "@ramiidv/arca-mtxca": "^0.1.0",
    "@ramiidv/arca-padron": "^0.1.0",
    "@ramiidv/arca-sire": "^0.1.0",
    "arca-cert": "^0.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.2"
  }
}
